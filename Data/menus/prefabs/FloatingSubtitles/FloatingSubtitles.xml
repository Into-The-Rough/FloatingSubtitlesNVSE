<rect name="FloatingSubtitles">
	<visible>&true;</visible>
	<locus>&true;</locus>
	<depth>50</depth>
		<rect name="FSOffScreen">
			<visible> 0 </visible>
			<locus>&true;</locus>
			<depth>52</depth>
			<_FSOffY>0.85</_FSOffY>
			<_FSOffWrapWidth>700</_FSOffWrapWidth>
		<x>
			<copy src="screen()" trait="width"/>
			<div> 2 </div>
		</x>
		<y>
			<copy src="me()" trait="_FSOffY"/>
			<mul src="screen()" trait="height"/>
		</y>
		<alpha> 255 </alpha>
			<text name="FSOffText">
				<string></string>
				<font>3</font>
				<systemcolor>1</systemcolor>
				<alpha> 255 </alpha>
				<wrapwidth><copy src="parent()" trait="_FSOffWrapWidth"/></wrapwidth>
			<justify>&center;</justify>
			<x> 0 </x>
			<y>
				<copy src="me()" trait="height"/>
				<div> -1 </div>
			</y>
		</text>
	</rect>
</rect>

<template name="FSSubtitle">
		<rect name="FSRect">
			<visible><copy src="me()" trait="_FSVisible"/></visible>
			<locus>&true;</locus>
			<depth>51</depth>
			<_FSVisible>0</_FSVisible>
			<_X>-1</_X>
			<_Y>-1</_Y>
			<_FSAlpha>255</_FSAlpha>
			<_FSText></_FSText>
			<_FSWrapWidth>400</_FSWrapWidth>
		<x>
			<copy src="me()" trait="_X"/>
			<sub>
				<copy> 10 </copy>
				<onlyif>
					<copy src="me()" trait="_X"/>
					<lte> -1 </lte>
				</onlyif>
			</sub>
			<mul src="screen()" trait="width"/>
		</x>
		<y>
			<copy src="me()" trait="_Y"/>
			<sub>
				<copy> 10 </copy>
				<onlyif>
					<copy src="me()" trait="_Y"/>
					<lte> -1 </lte>
				</onlyif>
			</sub>
			<mul src="screen()" trait="height"/>
		</y>
		<alpha><copy src="me()" trait="_FSAlpha"/></alpha>
			<text name="FSText">
				<string><copy src="parent()" trait="_FSText"/></string>
				<font>3</font>
				<systemcolor>1</systemcolor>
				<alpha><copy src="parent()" trait="_FSAlpha"/></alpha>
				<wrapwidth><copy src="parent()" trait="_FSWrapWidth"/></wrapwidth>
			<justify>&center;</justify>
			<x> 0 </x>
			<y>
				<copy src="me()" trait="height"/>
				<div> -1 </div>
			</y>
		</text>
	</rect>
</template>
